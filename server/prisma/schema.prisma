datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  Admin
  Manager
  Employee
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id                 String            @id @default(uuid()) @db.Uuid
  name               String
  email              String            @unique
  password           String
  role               Role              @default(Employee)
  avatar             String?
  department         String?
  designation        String?
  phone              String?
  isActive                 Boolean              @default(true)
  isOnline                 Boolean              @default(false)
  lastSeen                 DateTime?
  lastLogin                DateTime?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  
  createdProjects          Project[]            @relation("ProjectCreator")
  managedProjects          Project[]            @relation("ProjectManager")
  projectMemberships       ProjectMember[]
  activities               ProjectActivity[]
  assignedTasks            Task[]               @relation("TaskAssignee")
  createdTasks             Task[]               @relation("TaskCreator")
  taskComments             TaskComment[]
  taskAttachments          TaskAttachment[]
  taskActivities           TaskActivity[]
  conversationsCreated     Conversation[]       @relation("ConversationCreator")
  conversationMemberships  ConversationMember[]
  messagesSent             Message[]            @relation("MessageSender")
  messageReactions         MessageReaction[]
  notifications            Notification[]
  createdFolders           Folder[]             @relation("FolderCreator")
  uploadedFiles            File[]               @relation("FileUploader")
  uploadedFileVersions     FileVersion[]        @relation("FileVersionUploader")
  filePermissions          FilePermission[]
  meetingsOrganized        Meeting[]            @relation("MeetingOrganizer")
  meetingParticipations    MeetingParticipant[]
  meetingChatMessages      MeetingChatMessage[]
  meetingAttachments       MeetingAttachment[]
  aiConversations          AIConversation[]
  aiRequestLogs            AIRequestLog[]
  generatedReports         GeneratedReport[]
  departmentId             String?           @db.Uuid
  memberDepartment         Department?       @relation("DepartmentMembers", fields: [departmentId], references: [id], onDelete: SetNull)
  managedDepartments       Department[]      @relation("DepartmentManager")
  auditLogs                AuditLog[]
  bio                      String?
  website                  String?
  location                 String?
  preferences              UserPreference?
  sessions                 UserSession[]
  trustedDevices           TrustedDevice[]

  @@index([email])
}

model Project {
  id          String            @id @default(uuid()) @db.Uuid
  name        String
  code        String            @unique
  description String?
  status      ProjectStatus     @default(PLANNING)
  priority    ProjectPriority   @default(MEDIUM)
  startDate   DateTime?
  deadline    DateTime?
  createdBy   String            @db.Uuid
  creator     User              @relation("ProjectCreator", fields: [createdBy], references: [id])
  managerId   String            @db.Uuid
  manager     User              @relation("ProjectManager", fields: [managerId], references: [id])
  isArchived  Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  members      ProjectMember[]
  activities   ProjectActivity[]
  tasks        Task[]
  conversation Conversation?
  files            File[]
  folders          Folder[]
  meetings         Meeting[]
  generatedReports GeneratedReport[]

  @@index([code])
}

model ProjectMember {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([projectId, userId])
}

model ProjectActivity {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  action    String
  createdAt DateTime @default(now())
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id             String           @id @default(uuid()) @db.Uuid
  projectId      String           @db.Uuid
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  status         TaskStatus       @default(TODO)
  priority       TaskPriority     @default(MEDIUM)
  assignedTo     String?          @db.Uuid
  assignee       User?            @relation("TaskAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  createdBy      String           @db.Uuid
  creator        User             @relation("TaskCreator", fields: [createdBy], references: [id])
  estimatedHours Float?
  actualHours    Float?
  startDate      DateTime?
  deadline       DateTime?
  completedAt    DateTime?
  isArchived     Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  comments         TaskComment[]
  attachments      TaskAttachment[]
  activities       TaskActivity[]
  files            File[]
  generatedReports GeneratedReport[]

  @@index([projectId])
  @@index([assignedTo])
}

model TaskComment {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @db.Uuid
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
}

model TaskAttachment {
  id         String   @id @default(uuid()) @db.Uuid
  taskId     String   @db.Uuid
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileName   String
  fileUrl    String
  fileType   String
  uploadedBy String   @db.Uuid
  uploader   User     @relation(fields: [uploadedBy], references: [id])
  createdAt  DateTime @default(now())

  @@index([taskId])
}

model TaskActivity {
  id        String   @id @default(uuid()) @db.Uuid
  taskId     String   @db.Uuid
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  action     String
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())

  @@index([taskId])
}

enum ConversationType {
  DIRECT
  GROUP
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

enum NotificationType {
  MESSAGE
  PROJECT
  TASK
  SYSTEM
}

model Conversation {
  id          String               @id @default(uuid()) @db.Uuid
  type        ConversationType     @default(DIRECT)
  projectId   String?              @unique @db.Uuid
  project     Project?             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String?
  createdBy   String               @db.Uuid
  creator     User                 @relation("ConversationCreator", fields: [createdBy], references: [id])
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  
  members     ConversationMember[]
  messages    Message[]

  @@index([projectId])
}

model ConversationMember {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String       @db.Uuid
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime     @default(now())

  @@unique([conversationId, userId])
}

model Message {
  id              String            @id @default(uuid()) @db.Uuid
  conversationId  String            @db.Uuid
  conversation    Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        String            @db.Uuid
  sender          User              @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  message         String
  messageType     MessageType       @default(TEXT)
  edited          Boolean           @default(false)
  editedAt        DateTime?
  parentMessageId String?           @db.Uuid
  parentMessage   Message?          @relation("MessageReplies", fields: [parentMessageId], references: [id], onDelete: Cascade)
  replies         Message[]         @relation("MessageReplies")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  reactions       MessageReaction[]

  @@index([conversationId])
}

model MessageReaction {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @db.Uuid
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
}

model Notification {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @db.Uuid
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String
  type        NotificationType
  isRead      Boolean          @default(false)
  actionUrl   String?
  createdAt   DateTime         @default(now())

  @@index([userId])
}

enum Permission {
  VIEW
  DOWNLOAD
  EDIT
  OWNER
}

model Folder {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  parentId   String?  @db.Uuid
  parent     Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  subfolders Folder[] @relation("FolderHierarchy")
  projectId  String?  @db.Uuid
  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy  String   @db.Uuid
  creator    User     @relation("FolderCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  files      File[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
  @@index([parentId])
}

model File {
  id           String           @id @default(uuid()) @db.Uuid
  name         String
  originalName String
  publicId     String
  url          String
  thumbnailUrl String?
  mimeType     String
  extension    String
  size         Int
  folderId     String?          @db.Uuid
  folder       Folder?          @relation(fields: [folderId], references: [id], onDelete: Cascade)
  projectId    String?          @db.Uuid
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId       String?          @db.Uuid
  task         Task?            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy   String           @db.Uuid
  uploader     User             @relation("FileUploader", fields: [uploadedBy], references: [id], onDelete: Cascade)
  version      Int              @default(1)
  isDeleted    Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  versions           FileVersion[]
  permissions        FilePermission[]
  meetingAttachments MeetingAttachment[]

  @@index([folderId])
  @@index([projectId])
  @@index([taskId])
}

model FileVersion {
  id         String   @id @default(uuid()) @db.Uuid
  fileId     String   @db.Uuid
  file       File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  version    Int
  publicId   String
  url        String
  uploadedBy String   @db.Uuid
  uploader   User     @relation("FileVersionUploader", fields: [uploadedBy], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([fileId])
}

model FilePermission {
  id         String     @id @default(uuid()) @db.Uuid
  fileId     String     @db.Uuid
  file       File       @relation(fields: [fileId], references: [id], onDelete: Cascade)
  userId     String     @db.Uuid
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission

  @@unique([fileId, userId])
  @@index([fileId])
  @@index([userId])
}

enum MeetingStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  INVITED
  ACCEPTED
  DECLINED
  ATTENDED
  ABSENT
}

enum ParticipantRole {
  HOST
  CO_HOST
  PARTICIPANT
}

model Meeting {
  id           String               @id @default(uuid()) @db.Uuid
  title        String
  description  String?
  projectId    String?              @db.Uuid
  project      Project?             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organizerId  String               @db.Uuid
  organizer    User                 @relation("MeetingOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  meetingLink  String
  startTime    DateTime
  endTime      DateTime
  timezone     String
  status       MeetingStatus        @default(SCHEDULED)
  recordingUrl String?
  notes        String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  participants     MeetingParticipant[]
  attachments      MeetingAttachment[]
  chatMessages     MeetingChatMessage[]
  generatedReports GeneratedReport[]

  @@index([projectId])
  @@index([organizerId])
}

model MeetingParticipant {
  id               String           @id @default(uuid()) @db.Uuid
  meetingId        String           @db.Uuid
  meeting          Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId           String           @db.Uuid
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role             ParticipantRole  @default(PARTICIPANT)
  attendanceStatus AttendanceStatus @default(INVITED)
  joinedAt         DateTime?
  leftAt           DateTime?

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

model MeetingChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  meetingId String   @db.Uuid
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  senderId  String   @db.Uuid
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  message   String
  createdAt DateTime @default(now())

  @@index([meetingId])
  @@index([senderId])
}

model MeetingAttachment {
  id         String   @id @default(uuid()) @db.Uuid
  meetingId  String   @db.Uuid
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  fileId     String   @db.Uuid
  file       File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  uploadedBy String   @db.Uuid
  uploader   User     @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([meetingId])
  @@index([fileId])
  @@index([uploadedBy])
}

enum AIRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AIReportType {
  PROJECT
  MEETING
  TASK
  SPRINT
}

model AIConversation {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @db.Uuid
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  messages  AIMessage[]

  @@index([userId])
}

model AIMessage {
  id             String         @id @default(uuid()) @db.Uuid
  conversationId String         @db.Uuid
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           AIRole
  content        String
  tokens         Int?
  createdAt      DateTime       @default(now())

  @@index([conversationId])
}

model AIRequestLog {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature          String
  provider         String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  responseTime     Int
  status           String
  createdAt        DateTime @default(now())

  @@index([userId])
}

model GeneratedReport {
  id          String       @id @default(uuid()) @db.Uuid
  projectId   String?      @db.Uuid
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  meetingId   String?      @db.Uuid
  meeting     Meeting?     @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  taskId      String?      @db.Uuid
  task        Task?        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title       String
  content     String
  type        AIReportType
  generatedBy String       @db.Uuid
  creator     User         @relation(fields: [generatedBy], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())

  @@index([projectId])
  @@index([meetingId])
  @@index([taskId])
  @@index([generatedBy])
}

model AnalyticsSnapshot {
  id          String   @id @default(uuid()) @db.Uuid
  generatedAt DateTime @default(now())
  projectId   String?  @db.Uuid
  teamId      String?  @db.Uuid
  payload     Json
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Organization {
  id           String       @id @default(uuid()) @db.Uuid
  name         String
  logo         String?
  website      String?
  industry     String?
  address      String?
  phone        String?
  email        String?
  timezone     String?      @default("UTC")
  language     String?      @default("en")
  brandColors  String?      @default("#4f46e5")
  workingDays  String?      @default("Monday,Tuesday,Wednesday,Thursday,Friday")
  workingHours String?      @default("09:00-17:00")
  departments  Department[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Department {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  managerId      String?      @db.Uuid
  manager        User?        @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  organizationId String?      @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          User[]       @relation("DepartmentMembers")
  invitations    Invitation[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model SystemPermission {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique
  description String?
  module      String
  roles       RolePermission[]
}

model RolePermission {
  id           String           @id @default(uuid()) @db.Uuid
  role         Role
  permissionId String           @db.Uuid
  permission   SystemPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  @@unique([role, permissionId])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model Invitation {
  id           String           @id @default(uuid()) @db.Uuid
  email        String
  role         Role             @default(Employee)
  departmentId String?          @db.Uuid
  department   Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  token        String           @unique
  expiresAt    DateTime
  status       InvitationStatus @default(PENDING)
  createdAt    DateTime         @default(now())
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum Language {
  ENGLISH
  HINDI
  SPANISH
  FRENCH
  GERMAN
}

model UserPreference {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @unique @db.Uuid
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme                  Theme    @default(SYSTEM)
  language               Language @default(ENGLISH)
  timezone               String   @default("UTC")
  dateFormat             String   @default("YYYY-MM-DD")
  timeFormat             String   @default("24h")
  sidebarCollapsed       Boolean  @default(false)
  compactMode            Boolean  @default(false)
  emailNotifications     Boolean  @default(true)
  pushNotifications      Boolean  @default(true)
  meetingReminders       Boolean  @default(true)
  taskReminders          Boolean  @default(true)
  projectUpdates         Boolean  @default(true)
  chatNotifications      Boolean  @default(true)
  highContrast           Boolean  @default(false)
  reducedMotion          Boolean  @default(false)
  fontSize               String   @default("medium")
  profileVisibility      String   @default("public")
  activityVisibility     String   @default("public")
  onlineStatusVisibility String   @default("public")
  aiDataSharing          Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model UserSession {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  device     String
  browser    String
  ipAddress  String
  location   String?
  lastActive DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId])
}

model TrustedDevice {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName String
  fingerprint String
  lastUsed   DateTime @default(now())

  @@index([userId])
}
